# Fabric
FABRIC_SQL_SERVER=<workspace-id>-<lakehouse-id>.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DATABASE=lh-mbr-trucking

# Storage
STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net

# Foundry
FOUNDRY_PROJECT_ENDPOINT=https://...services.ai.azure.com/discovery/...
CONVERSATIONAL_AGENT_ID=
MBR_PRESENTATION_AGENT_ID=

# Managed Identity (injected by ACA — leave empty for local dev with DefaultAzureCredential)
AZURE_CLIENT_ID=

# Observability
APPLICATIONINSIGHTS_CONNECTION_STRING=

# CORS (set to longhaul-ui ACA URL in production)
CORS_ALLOW_ORIGIN=*
